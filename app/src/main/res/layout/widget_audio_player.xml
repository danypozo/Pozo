<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Track Icon / Album cover placeholder -->
    <ImageView
        android:id="@+id/widget_track_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_widget_music"
        android:scaleType="centerCrop"
        android:contentDescription="Icono de widget" />

    <!-- Details and Controls -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Title of Track -->
        <TextView
            android:id="@+id/widget_track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sin reproducción"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Status details or artist/playlist -->
        <TextView
            android:id="@+id/widget_track_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FTP Hub Player"
            android:textColor="#8F949F"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Playing Progress Bar with clickable interactivity -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp">

            <ProgressBar
                android:id="@+id/widget_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:minHeight="12dp"
                android:maxHeight="12dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#00ADB5"
                android:progressBackgroundTint="#2C323F" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/widget_btn_rewind_progress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="Retroceder 30s" />

                <ImageView
                    android:id="@+id/widget_btn_fastforward_progress"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="Avanzar 30s" />

            </LinearLayout>
        </FrameLayout>

        <!-- Control Actions Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="2dp">

            <ImageButton
                android:id="@+id/widget_btn_prev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_widget_prev"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:layout_marginEnd="20dp"
                android:contentDescription="Pista anterior" />

            <ImageButton
                android:id="@+id/widget_btn_play_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_widget_play"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:contentDescription="Reproducir o pausar" />

            <ImageButton
                android:id="@+id/widget_btn_next"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_widget_next"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:layout_marginStart="20dp"
                android:contentDescription="Siguiente pista" />

            <TextView
                android:id="@+id/widget_btn_go_live"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="🔴 DIRECTO"
                android:textColor="#FF3D71"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="@drawable/widget_live_bg"
                android:layout_marginStart="16dp"
                android:visibility="gone"
                android:contentDescription="Volver a directo" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
